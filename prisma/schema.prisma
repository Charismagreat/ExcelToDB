generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String?  // Hashed password
  fullName    String?
  employeeId  String?  @unique
  role        String   @default("VIEWER") // ADMIN, EDITOR, VIEWER
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  reports     Report[]
  createdRows ReportRow[] @relation("CreatedBy")
  updatedRows ReportRow[] @relation("UpdatedBy")
  authorizedReports Report[] @relation("AuthorizedReports")
}

model Report {
  id          String   @id @default(cuid())
  name        String
  sheetName   String?
  columns     String   // JSON string of column definitions: { name: string, type: string }[]
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  rows        ReportRow[]
  createdAt   DateTime @default(now())
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  authorizedUsers User[]   @relation("AuthorizedReports")
  slackWebhookUrl String?
}

model ReportRow {
  id          String   @id @default(cuid())
  data        String   // JSON string of row data: { [columnName]: value }
  contentHash String?  // 추가: 데이터 중복 감지를 위한 해시값
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id])
  
  // Auditing
  creatorId   String?
  creator     User?    @relation("CreatedBy", fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updaterId   String?
  updater     User?    @relation("UpdatedBy", fields: [updaterId], references: [id])
  updatedAt   DateTime @default(now()) @updatedAt
  
  // Logical Delete
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  histories   ReportRowHistory[]

  @@index([reportId, contentHash])
}

model ReportRowHistory {
  id          String   @id @default(cuid())
  rowId       String
  row         ReportRow @relation(fields: [rowId], references: [id])
  oldData     String   // JSON
  newData     String   // JSON
  changeType  String   // UPDATE, DELETE
  changedById String
  changedAt   DateTime @default(now())
}
