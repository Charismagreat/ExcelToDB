  {
    "name": "financehub_list_accounts",
    "description": "List bank accounts with balances, optionally filtered by bank or active status",
    "inputSchema": {
      "type": "object",
      "properties": {
        "bankId": {
          "type": "string",
          "description": "Filter by specific bank ID (e.g., \"shinhan\", \"kookmin\")"
        },
        "isActive": {
